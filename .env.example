# =========================
# Docker Compose 项目名
# =========================
COMPOSE_PROJECT_NAME=ollama-web-search
TZ=Asia/Shanghai

# =========================
# 对外访问端口（Nginx）
# =========================
PUBLIC_PORT=8080
GHCR_IMAGE=ghcr.io/haruka041/ollama-search-gateway:latest

# =========================
# 前端构建/运行配置
# =========================
VITE_API_BASE_URL=/api
FRONTEND_DEV_PORT=3000

# =========================
# 后端运行配置
# =========================
UVICORN_WORKERS=1
UVICORN_LOG_LEVEL=info
REQUEST_TIMEOUT_SECONDS=30
RETRY_ATTEMPTS=3
HEALTH_INTERVAL_SECONDS=15
NODE_FAILURE_THRESHOLD=3
DEFAULT_KEY_RATE_LIMIT_PER_MINUTE=60
ALLOW_NO_API_KEY=false
KEY_FAILURE_THRESHOLD=2
KEY_COOLDOWN_SECONDS=60

# 管理台登录（默认用户名 admin / 默认密码 admin123）
# 建议把 ADMIN_PASSWORD_HASH 与 JWT_SECRET 都改掉
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=sha256$240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9
JWT_SECRET=replace-with-a-long-random-secret

# =========================
# 可选默认 Ollama 节点（逗号分隔）
# =========================
# 示例：https://ollama.com,http://host.docker.internal:11434
OLLAMA_NODES=https://ollama.com
LB_STRATEGY=round-robin
HEALTH_PATH=/api/tags
WEB_SEARCH_PATH=/api/web_search
# 若要直连 SearxNG，可改为 /search（支持 GET /search?q=...&format=json）
# WEB_SEARCH_PATH=/search
CHAT_PATH=/api/chat

# Searx 兼容 Basic Auth（可选）
SEARX_COMPAT_USERNAME=
SEARX_COMPAT_PASSWORD_HASH=
SEARX_COMPAT_STORE_FILE=searx_compat.json

# 开发跨域白名单（逗号分隔）
# CORS_ALLOW_ORIGINS=http://127.0.0.1:13000,http://localhost:13000,http://127.0.0.1:3000,http://localhost:3000
